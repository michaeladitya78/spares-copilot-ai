{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/index-simple.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["server/**"] }
    }
  ],
  "env": { "NODE_ENV": "production" },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/index-simple.js" },
    { "source": "/ws", "destination": "/server/index-simple.js" },
    { "source": "/admin", "destination": "/dist/index.html" },
    { "source": "/bot", "destination": "/dist/index.html" },
    { "source": "/teams-config", "destination": "/dist/index.html" },
    { "source": "/", "destination": "/dist/index.html" },
    { "source": "/(.*\\.(js|css|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot))", "destination": "/dist/$1" },
    { "source": "/(.*)", "destination": "/dist/index.html" }
  ]
}
