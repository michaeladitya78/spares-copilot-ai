{
  "version": 2,
  "builds": [
    {
      "src": "server/index-simple.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index-simple.js"
    },
    {
      "src": "/ws",
      "dest": "/server/index-simple.js"
    },
    {
      "src": "/bot",
      "dest": "/dist/index.html"
    },
    {
      "src": "/",
      "dest": "/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ],
  "functions": {
    "server/index-simple.js": {
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
