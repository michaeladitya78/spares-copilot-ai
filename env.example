# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synapse_ai
DB_USER=postgres
DB_PASSWORD=password

# AI Provider Configuration
# Option 1: Use local AI stack (recommended for offline)
OLLAMA_HOST=http://localhost:11434
LOCAL_CHAT_MODEL=llama3.2:3b
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Option 2: Use external APIs (optional, for hybrid mode)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Microsoft Teams Bot Configuration
MICROSOFT_APP_ID=your_teams_app_id
MICROSOFT_APP_PASSWORD=your_teams_app_password
MICROSOFT_APP_TYPE=MultiTenant
MICROSOFT_APP_TENANT_ID=your_tenant_id

# Server Configuration
PORT=8787
NODE_ENV=development

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379

# Security (generate random strings for production)
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# File Upload Configuration
MAX_FILE_SIZE=50MB
UPLOAD_DIR=./uploads

# Training Configuration
TRAINING_DATA_DIR=./training_data
BATCH_SIZE=100
EMBEDDING_DIMENSION=384
